# Copie en .env et adapte selon l'environnement.

# Connexion base de données (SQLAlchemy URL).
# Exemples :
#   sqlite:///./finess.db
#   postgresql+psycopg2://user:pwd@host:5432/finess
DATABASE_URL=sqlite:///./finess.db

# Environnement : development | staging | production
APP_ENV=development

# Niveau de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Fichier de log optionnel (rotation 10MB x 5). Laisser vide pour stdout seul.
# LOG_FILE=/var/log/finess-ars/app.log

# Limite maximale d'upload CSV (en Mo).
MAX_UPLOAD_MB=100

# API SIRENE (INSEE) — laisser vide pour désactiver la vérification SIRET.
SIRENE_API_BASE=https://api.insee.fr/entreprises/sirene/V3.11
# SIRENE_API_TOKEN=<bearer_token>
